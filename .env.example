# Public Supabase configuration (use one public key name, not both)
NEXT_PUBLIC_SUPABASE_URL=
# Current Supabase projects use a publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy projects can use an anon key instead of the publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase access — never expose this as NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3010

# Phase 2+ server-only integrations
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional observability and social integrations
META_APP_ID=
TWITTER_BEARER_TOKEN=
SENTRY_DSN=
